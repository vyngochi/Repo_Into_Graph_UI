{
  "name": "repo-into-graph-desktop",
  "version": "1.0.0",
  "description": "Desktop app for Repo Into Graph - Static Code Analyzer",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"vite\" \"wait-on tcp:5173 && electron . --dev\"",
    "build": "tsc && vite build",
    "build:libs": "esbuild scripts/bundle-graph-libs.js --bundle --format=iife --outfile=public/lib/graph-libs.bundle.js --minify --platform=browser"
  },
  "keywords": [
    "electron",
    "code-analysis",
    "graph",
    "static-analysis"
  ],
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "electron": "^23.1.3",
    "esbuild": "^0.28.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "graphology": "^0.26.0",
    "graphology-layout-forceatlas2": "^0.10.1",
    "lucide-react": "^1.18.0",
    "prismjs": "^1.30.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "react-syntax-highlighter": "^16.1.1",
    "sigma": "^3.0.3",
    "zustand": "^5.0.14"
  }
}
